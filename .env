# ── HTTP server ────────────────────────────────────────────────────────────
PORT=8080
GIN_MODE=debug
CORS_ALLOWED_ORIGINS=*

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=crm_user
DB_PASSWORD=crm_password
DB_NAME=crm_db
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h
DB_AUTO_MIGRATE=true

# ── Keycloak / OIDC ────────────────────────────────────────────────────────
KEYCLOAK_BASE_URL=http://localhost:8081

# Admin realm — back-office CRM operators
KEYCLOAK_ADMIN_REALM=crm-admin
KEYCLOAK_ADMIN_AUDIENCE=
KEYCLOAK_ADMIN_REQUIRED_ROLE=CRM

# Client realm — tenant users
KEYCLOAK_CLIENT_REALM=crm-clients
KEYCLOAK_CLIENT_AUDIENCE=

# Issuer overrides (blank = derive {BASE}/realms/{REALM})
KEYCLOAK_ADMIN_ISSUER=
KEYCLOAK_CLIENT_ISSUER=

JWKS_CACHE_TTL=15m
TOKEN_CLOCK_SKEW=1m

# ── Tenancy ────────────────────────────────────────────────────────────────
TENANT_HEADER=X-Tenant-ID
