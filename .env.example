# ──────────────────────────────────────────────────────────────────────────
# CRM Backend — environment configuration
# Copy to `.env` and adjust. Everything is env-driven so the same binary can be
# deployed to any environment (local / staging / prod) without code changes.
# ──────────────────────────────────────────────────────────────────────────

# ── HTTP server ────────────────────────────────────────────────────────────
PORT=8080
# gin mode: debug | release | test
GIN_MODE=debug
# Comma-separated allowed CORS origins (use * only for local dev)
CORS_ALLOWED_ORIGINS=*

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=crm_user
DB_PASSWORD=crm_password
DB_NAME=crm_db
# disable | require | verify-ca | verify-full
DB_SSLMODE=disable
DB_TIMEZONE=UTC
# Connection pool tuning
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h
# Run GORM AutoMigrate on startup (true/false)
DB_AUTO_MIGRATE=true

# ── Keycloak / OIDC ────────────────────────────────────────────────────────
# Base URL of the Keycloak server (no trailing slash)
KEYCLOAK_BASE_URL=https://keycloak.example.com

# Admin realm — back-office CRM operators
KEYCLOAK_ADMIN_REALM=crm-admin
# Optional: expected audience/authorized party for admin tokens (blank = skip check)
KEYCLOAK_ADMIN_AUDIENCE=
# Realm role required to administer tenants
KEYCLOAK_ADMIN_REQUIRED_ROLE=CRM

# Client realm — tenant users
KEYCLOAK_CLIENT_REALM=crm-clients
# Optional: expected audience/authorized party for client tokens (blank = skip check)
KEYCLOAK_CLIENT_AUDIENCE=

# Issuer URLs are derived as {BASE}/realms/{REALM} by default.
# Override only if your issuer differs (e.g. behind a proxy / different hostname).
KEYCLOAK_ADMIN_ISSUER=
KEYCLOAK_CLIENT_ISSUER=

# JWKS cache: how long to cache realm signing keys before refresh
JWKS_CACHE_TTL=15m
# Allowed clock skew when validating exp/nbf
TOKEN_CLOCK_SKEW=1m

# ── Tenancy ────────────────────────────────────────────────────────────────
# Header clients use to select the active tenant on client-domain requests
TENANT_HEADER=X-Tenant-ID
